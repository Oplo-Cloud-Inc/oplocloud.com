# Copy to ".env" (same folder) before running `docker compose up`.
# cp .env.example .env

# ZITADEL's master encryption key. MUST be exactly 32 characters.
# Generate a fresh one:  openssl rand -base64 24 | cut -c1-32
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# First admin (console) login. Username is "root". Change this password.
ZITADEL_ADMIN_PASSWORD=RootPassword1!
